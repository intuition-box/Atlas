# DATABASE
DATABASE_URL="postgresql://...pooled..."
DATABASE_URL_UNPOOLED="postgresql://...nonpooled..." # For uses requiring a connection without pgbouncer

# CRON BEARER TOKEN
CRON_SECRET="long-random-secret"

# AUTH
NEXT_DEV_INSECURE_COOKIES=true   # to bypass csrf security, set this to true on dev mode ONLY!
AUTH_SECRET="long-random-secret"
AUTH_URL=""
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""
# X OAuth (optional — enables account linking)
AUTH_X_ID=""
AUTH_X_SECRET=""
# Github OAuth (optional — enables account linking)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# STORAGE
R2_PUBLIC_BASE_URL=""     # e.g. https://cdn.yourdomain.com or https://<account>.r2.cloudflarestorage.com/<bucket>
R2_ACCOUNT_ID=""
R2_BUCKET=atlas
R2_TOKEN=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_ENDPOINT=""            # e.g. https://<account>.r2.cloudflarestorage.com

# INTUITION
NEXT_PUBLIC_INTUITION_ENABLED="true"
NEXT_PUBLIC_INTUITION_TESTNET="true"

# WalletConnect (optional — enables mobile wallets + QR code)
# Get a project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# CRON
CRON_SECRET=""
