generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// -----------------------------
/// Enums
/// -----------------------------

enum MembershipRole {
  OWNER
  ADMIN
  MODERATOR
  MEMBER
}

enum MembershipStatus {
  /// Waiting for review / approval.
  PENDING

  /// Approved member / approved application.
  APPROVED

  /// Rejected member / rejected application.
  REJECTED

  /// Applicant withdrew their own application.
  WITHDRAWN

  /// Membership is banned.
  BANNED
}

enum OrbitLevel {
  EXPLORER
  PARTICIPANT
  CONTRIBUTOR
  ADVOCATE
}

// AttestationType is now defined in src/config/attestations.ts
// Stored as String in the database for flexibility

enum ScoringType {
  COMMUNITY_CREATED
  JOINED

  ATTESTED
  ATTESTATION_RETRACTED
  ATTESTATION_SUPERSEDED

  PROFILE_UPDATED
  COMMUNITY_UPDATED
  ROLE_UPDATED
  ORBIT_OVERRIDE
}

enum HandleOwnerType {
  USER
  COMMUNITY
}

enum HandleStatus {
  /// Currently assigned and resolvable in routes.
  ACTIVE

  /// Not assigned (routes should 404).
  /// Can be reclaimed by the last owner until `reclaimUntil`.
  /// After `availableAt`, anyone can claim it.
  RELEASED

  /// Permanently unavailable (routes should 404 forever).
  /// Used when a user/community is deleted.
  RETIRED
}

enum CommunityConfigType {
  MEMBERSHIP
  ORBIT
}

/// -----------------------------
/// Core: People & Accounts
/// -----------------------------

model User {
  id            String   @id @default(cuid())

  // Auth.js core fields
  name          String?
  email         String?  @unique
  emailVerified DateTime?
  image         String?  // Auth.js user image (you can store the same URL as avatarUrl here)

  // App-specific identity
  discordId     String?  @unique
  discordHandle String?
  twitterId     String?  @unique
  twitterHandle String?
  walletAddress String?  @unique   // denormalized linked wallet (lowercase hex)
  avatarUrl     String?  // preferred profile image URL (e.g., Cloudflare R2)

  // Onboarding state (server source of truth)
  onboarded     Boolean  @default(false)
  onboardedAt   DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastActiveAt  DateTime?

  // Profile
  headline      String?
  bio           String?
  location      String?
  links         String[] @default([]) // ex: ["https://github.com/x", "https://x.com/y"]
  skills        String[] @default([]) // ex: ["TypeScript", "Design Systems"]
  tags          String[] @default([]) // ex: ["open-source", "dao", "mentor"]
  languages     String[] @default([]) // ex: ["English", "Portuguese"]
  contactPreference  String?  // "discord" | "email" | "telegram" | "x"

  // Auth.js relations
  accounts      Account[]
  sessions      Session[]

  // App relations
  ownedCommunities      Community[] @relation("CommunityOwner")
  communityConfigEdits  CommunityConfigRevision[] @relation("CommunityConfigMember")
  memberships           Membership[]
  applications          Application[] @relation("ApplicationApplicant")
  applicationsReviewed  Application[] @relation("ApplicationReviewer")
  attestationsGiven     Attestation[] @relation("attestationsGiven")
  attestationsReceived  Attestation[] @relation("attestationsReceived")
  attestationsRevoked   Attestation[] @relation("attestationsRevokedBy")
  scoringEvents         ScoringEvent[] @relation("scoringActor")
  scoringSubjects       ScoringEvent[] @relation("ScoringSubject")

  // Security
  securityPrefs   UserSecurityPrefs? @relation("UserSecurityPrefs")
  securityEvents  SecurityEvent[]    @relation("UserSecurityEvents")

  // Wallet
  wallets             Wallet[]

  // MFA + passkeys
  webAuthnCredentials WebAuthnCredential[]
  mfaTotp             MfaTotp?
  mfaBackupCodes      MfaBackupCode[]

  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

/// Create account or sign in with passkeys.
model WebAuthnCredential {
  id             String    @id @default(cuid())
  userId         String

  nickname       String?

  /// Base64url credential ID.
  credentialId   String    @unique

  /// Base64url-encoded public key.
  publicKey      String

  /// Signature counter.
  counter        Int       @default(0)

  /// Transport hints (e.g. ["usb","nfc","internal"]).
  transports     String[]

  deviceType     String?
  backedUp       Boolean   @default(false)
  attestationFmt String?

  createdAt      DateTime  @default(now())
  lastUsedAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Time-based one-time password (TOTP) secret for MFA.
/// Store the secret encrypted at rest (`secretEnc`).
model MfaTotp {
  id             String    @id @default(cuid())
  userId         String    @unique

  /// Encrypted secret (see `src/lib/security/crypto.ts`).
  secretEnc      String

  algorithm      String    @default("SHA1")
  digits         Int       @default(6)
  period         Int       @default(30)

  enabledAt      DateTime?
  lastVerifiedAt DateTime?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Backup codes for MFA (one-time use; store hashes only).
model MfaBackupCode {
  id        String    @id @default(cuid())
  userId    String

  /// scrypt hash (see `src/lib/security/crypto.ts`).
  codeHash  String

  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, codeHash])
  @@index([userId])
}

/// Global handle registry used for pretty URLs and UI display.
///
/// Routing rule of thumb:
/// - Only rows with status = ACTIVE should resolve.
/// - RELEASED and RETIRED must return 404.
///
/// Reuse policy (enforced in application logic):
/// - On handle change: set previous handle to RELEASED,
///   set lastOwnerType/lastOwnerId, set releasedAt=now, reclaimUntil=now+7d, availableAt=now+30d.
/// - Reclaim: only allowed for the last owner while now <= reclaimUntil.
/// - Public claim: only allowed when now >= availableAt.
/// - Deletion: set status=RETIRED and set retiredAt=now; never becomes available.
model Handle {
  id            String         @id @default(cuid())

  /// Canonical display value used in URLs (may include hyphens).
  name          String         @unique @db.VarChar(32)

  /// Hyphen-insensitive uniqueness key to prevent confusing collisions.
  /// Example: "saulo-santos" and "saulosantos" both map to key "saulosantos".
  /// This must be computed in application logic as: `name.replaceAll("-", "")`.
  key           String         @unique @db.VarChar(32)

  status        HandleStatus   @default(ACTIVE)

  /// Last owner info to support short reclaim windows.
  lastOwnerType HandleOwnerType?
  lastOwnerId   String?

  claimedAt     DateTime       @default(now())
  releasedAt    DateTime?

  /// Last-owner reclaim cutoff (e.g., releasedAt + 7 days).
  reclaimUntil  DateTime?

  /// Public availability time (e.g., releasedAt + 30 days).
  availableAt   DateTime?

  retiredAt     DateTime?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  /// Canonical current owner mapping (enforced by DB constraints).
  owner HandleOwner?

  @@index([status, availableAt])
  @@index([lastOwnerType, lastOwnerId])
}

/// Canonical current owner mapping for a handle.
///
/// This table exists to make ownership race-safe and DB-enforced:
/// - Each handle can have at most one owner (handleId is the primary key).
/// - Each owner can have at most one handle (unique on [ownerType, ownerId]).
model HandleOwner {
  /// One owner mapping per handle.
  handleId   String         @id

  ownerType  HandleOwnerType
  ownerId    String

  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  handle     Handle         @relation(fields: [handleId], references: [id], onDelete: Cascade)

  @@unique([ownerType, ownerId])
  @@index([ownerType, ownerId])
}

/// -----------------------------
/// Communities and members
/// -----------------------------

model Community {
  id          String   @id @default(cuid())

  /// Small visual identifier for the community (e.g., an emoji like "🪐").
  icon        String?  @db.VarChar(16)

  name        String
  description String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId     String
  owner       User     @relation("CommunityOwner", fields: [ownerId], references: [id], onDelete: Restrict)

  // Settings (keep flexible)
  isPublicDirectory Boolean @default(true)

  /// If false, users cannot submit new applications to join this community.
  isMembershipOpen Boolean @default(true)

  // Social links (plain URLs, no OAuth)
  discordUrl  String?
  xUrl        String?
  telegramUrl String?
  githubUrl   String?
  websiteUrl  String?

  // JSON settings so you can evolve without migrations every week
  membershipConfig Json?
  orbitConfig       Json? // thresholds, weights, etc.

  configRevisions CommunityConfigRevision[]
  memberships Membership[]
  applications Application[]
  scoringEvents ScoringEvent[]

  @@index([ownerId])
  @@index([createdAt])
}

/// Append-only history of community config changes.
///
/// Why this exists:
/// - audit: who changed config and when
/// - rollback: re-apply an older revision as the current config
///
/// We keep the current config on `Community` for fast reads,
/// and write a revision row whenever config changes.
model CommunityConfigRevision {
  id          String             @id @default(cuid())

  communityId String
  type        CommunityConfigType

  /// Snapshot of the config at this revision.
  config      Json?

  /// Who authored the change (nullable for system migrations).
  memberId     String?

  /// Optional human-readable note (e.g. "initial", "updated form", "rollback").
  note        String?            @db.VarChar(200)

  createdAt   DateTime           @default(now())

  community   Community          @relation(fields: [communityId], references: [id], onDelete: Cascade)
  member      User?              @relation("CommunityConfigMember", fields: [memberId], references: [id], onDelete: SetNull)

  @@index([communityId, type, createdAt])
  @@index([memberId, createdAt])
}

model Membership {
  id          String   @id @default(cuid())
  userId      String
  communityId String

  role        MembershipRole   @default(MEMBER)
  status      MembershipStatus @default(PENDING)

  // Orbit + scoring
  orbitLevel        OrbitLevel @default(EXPLORER)
  orbitLevelOverride OrbitLevel?
  loveScore         Int        @default(0)
  reachScore        Int        @default(0)
  gravityScore      Int        @default(0)

  lastActiveAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  approvedAt   DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
  @@index([communityId, status])
  @@index([communityId, role])
  @@index([communityId, gravityScore])
}

model Application {
  id          String   @id @default(cuid())
  userId      String
  communityId String

  status      MembershipStatus @default(PENDING)
  answers     Json              // store RHF output here (validated server-side)

  reviewerId  String?
  reviewedAt  DateTime?

  /// Optional reviewer note (e.g., reason for rejection).
  reviewNote  String?  @db.VarChar(500)

  reviewer    User?    @relation("ApplicationReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation("ApplicationApplicant", fields: [userId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  // Multiple applications allowed per user/community (full history)
  @@index([userId, communityId, createdAt])
  @@index([communityId, status, createdAt])
}

/// -----------------------------
/// Attestations and facts
/// -----------------------------

model Attestation {
  id          String   @id @default(cuid())
  fromUserId  String
  toUserId    String

  type        String   // AttestationType from src/config/attestations.ts
  confidence  Float?   // optional 0..1

  /// Soft-delete (retract) support.
  /// When revokedAt is set, this attestation should be treated as inactive.
  revokedAt       DateTime?
  revokedByUserId String?
  revokedReason   String?

  /// Append-only "update" support.
  /// When supersededById is set, this attestation has been replaced by a newer one.
  supersededById  String?

  /// Blockchain minting support.
  /// When mintedAt is set, this attestation has been committed onchain.
  mintedAt    DateTime?
  mintTxHash  String?    // blockchain transaction hash
  onchainId   String?    // ID assigned by Intuition protocol

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  fromUser  User @relation("attestationsGiven", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser    User @relation("attestationsReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  /// Who revoked it (optional; can be the author).
  revokedBy User? @relation("attestationsRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  /// Self relation for supersede chain.
  supersededBy Attestation? @relation("AttestationSupersede", fields: [supersededById], references: [id], onDelete: SetNull)
  supersedes   Attestation[] @relation("AttestationSupersede")

  @@index([fromUserId, createdAt])
  @@index([toUserId, createdAt])
  @@index([fromUserId, toUserId, type])
  @@index([revokedAt, createdAt])
  @@index([supersededById])
  @@index([fromUserId, mintedAt])  // for querying unminted attestations
}

/// -----------------------------
/// Scoring events
/// -----------------------------

model ScoringEvent {
  id            String    @id @default(cuid())
  communityId   String
  actorId       String
  subjectUserId String?

  type          ScoringType
  metadata      Json?
  createdAt     DateTime  @default(now())

  community     Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  actor         User      @relation("scoringActor", fields: [actorId], references: [id], onDelete: Cascade)
  subjectUser   User?     @relation("ScoringSubject", fields: [subjectUserId], references: [id], onDelete: SetNull)

  @@index([communityId, createdAt])
  @@index([communityId, actorId, createdAt])
  @@index([communityId, type, createdAt])
  @@index([communityId, subjectUserId, createdAt])
}

/// -----------------------------
/// Security: preferences + events
/// -----------------------------

/// Per-user notification preferences for security-related emails.
/// Defaults are intentionally "on".
model UserSecurityPrefs {
  userId           String  @id

  emailOnLogin       Boolean @default(true)
  emailOnNewDevice   Boolean @default(true)
  emailOnMfaChange   Boolean @default(true)
  emailOnBackupCodes Boolean @default(true)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User    @relation("UserSecurityPrefs", fields: [userId], references: [id], onDelete: Cascade)
}

/// Append-only audit log for high-signal security actions.
model SecurityEvent {
  id        String   @id @default(cuid())
  userId    String

  /// Event type string, e.g. "mfa.totp.enabled".
  type      String   @db.VarChar(64)

  ip        String?
  userAgent String?
  metadata  Json?

  createdAt DateTime @default(now())

  user      User     @relation("UserSecurityEvents", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

/// -----------------------------
/// API Idempotency
/// -----------------------------

model ApiIdempotency {
  id         String   @id @default(cuid())

  /// Idempotency key provided by the client.
  key        String

  /// Stable route identifier (usually request pathname).
  route      String

  /// Scope idempotency per user or globally.
  /// Use a stable sentinel like "global" when not scoped.
  userId     String

  /// Optional hash of request body to detect key reuse with different payloads.
  bodyHash   String?

  /// HTTP status to replay.
  statusCode Int

  /// Stored ApiEnvelope (see `src/lib/api-shapes.ts`) for replay.
  response   Json?

  /// Non-null while a handler is processing the first request.
  lockedAt   DateTime?

  /// Expiration for this idempotency record.
  expiresAt  DateTime

  createdAt  DateTime @default(now())

  @@unique([key, route, userId])
  @@index([expiresAt])
  @@index([userId])
}

/// -----------------------------
/// Wallet
/// -----------------------------

/// Linked Ethereum wallet for a user.
/// One user may have at most one linked wallet (enforced in application logic).
model Wallet {
  id        String   @id @default(cuid())
  userId    String
  address   String   @unique   // lowercase hex, e.g. "0xabcd..."
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}